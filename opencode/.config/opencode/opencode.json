{
  "$schema": "https://opencode.ai/config.json",
  "model": "vercel/openai/gpt-5.5",
  "mcp": {
    "linear": {
      "type": "remote",
      "url": "https://mcp.linear.app/mcp",
      "enabled": true
    },
    "datadog": {
      "type": "remote",
      "url": "https://mcp.datadoghq.com/api/unstable/mcp-server/mcp?toolsets=all",
      "enabled": true
    }
  },
  "tools": {
    "linear_*": false,
    "datadog_*": false
  },
  "permission": {
    "external_directory": {
      "/tmp/**": "allow",
      "/private/tmp/**": "allow",
      "~/.cargo/registry/**": "allow"
    }
  }
}
