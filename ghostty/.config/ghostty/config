background="#000000"
font-family="GeistMono Nerd Font"
window-padding-x="10"
window-padding-balance="true"
window-padding-color="extend"
window-padding-y="2"
cursor-style = block
cursor-style-blink = false
shell-integration-features = no-cursor,no-title
clipboard-trim-trailing-spaces="true"
clipboard-paste-protection="true"
macos-titlebar-style="tabs"
macos-titlebar-proxy-icon="hidden"
macos-window-shadow="false"
font-size="16"
font-thicken
font-thicken-strength="50"
font-feature="-calt"
font-feature="-liga"
font-feature="-dlig"
mouse-hide-while-typing="true"
quit-after-last-window-closed=true
unfocused-split-opacity=1.0
split-divider-color="#444444"

# Font size
keybind = all:ctrl+==increase_font_size:1
keybind = all:ctrl++=increase_font_size:1
keybind = all:ctrl+-=decrease_font_size:1
keybind = all:ctrl+0=reset_font_size
keybind = all:ctrl+shift+a=set_font_size:36
keybind = all:ctrl+shift+b=reset_font_size

# tmux-like leader bindings.
keybind = ctrl+a>ctrl+a=text:\x01
keybind = ctrl+a>ctrl+r=reload_config
keybind = ctrl+a>c=new_tab
keybind = ctrl+a>ctrl+c=new_tab
keybind = ctrl+a>n=next_tab
keybind = ctrl+a>ctrl+n=next_tab
keybind = ctrl+a>p=previous_tab
keybind = ctrl+a>ctrl+p=previous_tab
keybind = ctrl+a>q=close_tab:this
keybind = ctrl+a>ctrl+q=close_tab:this
keybind = ctrl+a>r=prompt_tab_title
keybind = ctrl+a>h=new_split:right
keybind = ctrl+a>ctrl+h=new_split:right
keybind = ctrl+a>v=new_split:down
keybind = ctrl+a>ctrl+v=new_split:down
keybind = ctrl+a>e=equalize_splits
keybind = ctrl+a>ctrl+e=equalize_splits

# Large split jumps work best from an equalized layout.
keybind = ctrl+a>shift+y=resize_split:left,300
keybind = ctrl+a>shift+u=resize_split:right,300
keybind = ctrl+a>shift+g=resize_split:up,180
keybind = ctrl+a>shift+t=resize_split:down,180

keybind = ctrl+a>y=resize_split:left,50
keybind = ctrl+a>ctrl+y=resize_split:left,50
keybind = ctrl+a>u=resize_split:right,50
keybind = ctrl+a>ctrl+u=resize_split:right,50
keybind = ctrl+a>g=resize_split:up,50
keybind = ctrl+a>ctrl+g=resize_split:up,50
keybind = ctrl+a>t=resize_split:down,50
keybind = ctrl+a>ctrl+t=resize_split:down,50
keybind = ctrl+a>z=toggle_split_zoom
keybind = ctrl+a>ctrl+z=toggle_split_zoom
keybind = ctrl+a>left=move_tab:-1
keybind = ctrl+a>ctrl+left=move_tab:-1
keybind = ctrl+a>right=move_tab:1
keybind = ctrl+a>ctrl+right=move_tab:1

# Pane navigation mirrors your prefix-less tmux binds.
keybind = ctrl+l=goto_split:left
keybind = ctrl+semicolon=goto_split:right
keybind = ctrl+k=goto_split:top
keybind = ctrl+j=goto_split:bottom
