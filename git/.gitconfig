[user]
	email = anthonyshew@gmail.com
	name = Anthony Shew
	signingkey = ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIC+NScm0wQ4XwJ+kx50pIWYLEqsQcIAc7EsEgoCeggVL
[core]
	editor = nvim --clean
	excludesfile = ~/.gitignore_global
[init]
	defaultBranch = main
[color]
	ui = true
[pull]
	rebase = false
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[push]
	default = current
[http]
	postBuffer = 157286400
[diff]
	tool = critique
[difftool "critique"]
	cmd = critique difftool \"$LOCAL\" \"$REMOTE\"
[gpg]
	format = ssh
[gpg "ssh"]
	program = /Applications/1Password.app/Contents/MacOS/op-ssh-sign
[commit]
	gpgsign = true
[include]
	path = ~/.config/git/platform.gitconfig
